# Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Google OAuth (일정·Gmail — 필수)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# 카카오 로그인 (선택) — 콘솔 Redirect: {NEXTAUTH_URL}/api/auth/callback/kakao
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=

# 네이버 로그인 (선택) — Callback: {NEXTAUTH_URL}/api/auth/callback/naver
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# Database
DATABASE_URL=file:./data/db.sqlite

# Encryption (OAuth refresh_token JWT 암호화, AES-256-GCM 키 유도용)
SECRET_KEY=your-encryption-key-here-generate-with-openssl-rand-base64-32
# OAuth 전용 키(선택). 없으면 SECRET_KEY 사용
# OAUTH_TOKEN_SECRET=...

# LLM (OpenAI - optional)
OPENAI_API_KEY=your-openai-api-key

# LM Studio (optional - if using local LLM)
# LM_STUDIO_ENDPOINT=http://192.168.0.2:1234
# LM_STUDIO_MODEL=nvidia/nemotron-3-nano-4b
